# Signal Found API base URL
# Production: https://api.signal-found.io  (default — no change needed for most users)
# Local dev: http://localhost:8080
ONBOARD_API_BASE_URL=https://api.signal-found.io

# Your Signal Found client ID (get this from your account dashboard)
ONBOARD_API_CLIENT_ID=

# Request timeout in seconds (default: 60)
ONBOARD_API_TIMEOUT_SECONDS=60

# MCP transport: stdio (for Claude Desktop/Cursor) or streamable-http (for hosted deployments)
MCP_TRANSPORT=stdio

# Host to bind when using HTTP transport
MCP_HOST=0.0.0.0
